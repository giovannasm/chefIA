<!-- versão mais completa -->
<div class="container mt-5">
  <div class="row justify-content-center">

    <div class="col-lg-6">

      <div class="text-center mb-4">
        <h1>👩‍🍳 ChefIA, o que eu posso cozinhar?</h1>
        <p class="text-muted">
          Quais ingredientes você tem? Vamos usar a inteligência artificial para sugerir uma receita deliciosa com o que você tem na cozinha!
        </p>
      </div>

      <div class="card shadow-sm">
        <div class="card-body p-4">

          <%= simple_form_for @suggestion do |f| %>

            <div class="mb-3">
              <%= f.label :ingredients, "Seus ingredientes", class: "form-label" %>

              <%= f.text_area :ingredients,
                rows: 6,
                class: "form-control",
                placeholder: "ovos\nqueijo\ntomate\npão" %>
            </div>

            <div class="d-grid">
              <%= f.submit "Gerar receita com IA",
                class: "btn btn-primary btn-lg" %>
            </div>

            <div class="mt-3 d-grid">
              <%= link_to "Ver todas as receitas",
                recipe_suggestions_path,
                class: "btn btn-outline-secondary" %>
            </div>
          <% end %>


        </div>
      </div>

    </div>

  </div>
</div>
